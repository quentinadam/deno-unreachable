{
  "name": "@quentinadam/unreachable",
  "version": "0.1.2",
  "description": "A simple library to assert unreachable code paths",
  "license": "MIT",
  "author": "Quentin Adam",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quentinadam/deno-unreachable.git"
  },
  "exports": "./src/mod.ts",
  "fmt": {
    "singleQuote": true,
    "lineWidth": 120
  },
  "compilerOptions": {
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true
  },
  "imports": {
    "@quentinadam/assert": "jsr:@quentinadam/assert@^0.1.18",
    "typescript": "npm:typescript@^6.0.2"
  }
}
